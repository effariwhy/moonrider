{
  "name": "Moon Rider",
  "image": "node:11-buster",

  // Forward the webpack-dev-server port
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Webpack Dev Server",
      "onAutoForward": "openBrowser"
    }
  },

  // Install dependencies automatically when the container starts
  "postCreateCommand": "npm install",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.vscode-js-debug",
        "glsl-canvas.glsl-canvas"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.tabSize": 2,
        "files.eol": "\n"
      }
    }
  },

  "remoteUser": "node"
}